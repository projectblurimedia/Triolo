NODE_ENV=development
PORT=4000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/marketplace_dev
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/marketplace_test

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5

# SMS provider for OTP delivery only (never used for service-completion PINs)
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_SENDER_ID=

FCM_SERVER_KEY=
